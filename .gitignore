# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Production builds
/build
dist/
dist

# ====================
# SECRETS / ENV FILES
# ====================
# NEVER commit local env files. Use .env.example for templates.
.env
.env.*
!.env.example
!.env.*.example
backend/.env
frontend/.env
backend/.env.*
frontend/.env.*
!backend/.env.example
!frontend/.env.example
*token.json*
*credentials.json*
*secret*
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Test reports
/test_reports/
/tests/__pycache__/
backend_test.py

# Memory / agent runtime files (do not commit)
/memory/
/.emergent/

# Build caches
.cache/
*.pack

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.deb
*.dylib

# Mobile development
android-sdk/
frontend/node_modules/.cache/

# Deployment artefacts
.vercel
.wrangler/
wrangler.toml.local

# OS / scratch
*.swp
*.swo
.tmp/
frontend/node_modules/.cache/default-development/0.pack
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials
